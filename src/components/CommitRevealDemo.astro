<div class="demo-panel" id="commit-reveal-demo">
  <p class="demo-status" id="demo-status">Deriving generators g, h…</p>

  <div class="demo-row">
    <label for="demo-m">Your secret message, m</label>
    <div class="demo-input-row">
      <input id="demo-m" type="number" value="42" min="0" step="1" />
      <button id="demo-commit-btn" type="button" disabled>Commit</button>
    </div>
  </div>

  <div class="demo-divider" id="demo-output" hidden>
    <p class="demo-label">Commitment C = g^m · h^r mod p</p>
    <code class="demo-commitment" id="demo-commitment-value"></code>
    <p class="demo-hint">m and r are not shown — this is all the verifier sees.</p>
    <button id="demo-reveal-btn" type="button">Reveal</button>
  </div>

  <div class="demo-divider" id="demo-reveal" hidden>
    <p>Opened with <code>m = <span id="reveal-m"></span></code>, <code>r = <span id="reveal-r"></span></code></p>
    <p class="demo-check" id="reveal-check"></p>
  </div>
</div>

<script>
  import { getGenerators, commit, randomExponent, verify, toShortHex } from '../lib/classic-pedersen.js';

  const statusEl = document.getElementById('demo-status')!;
  const mInput = document.getElementById('demo-m') as HTMLInputElement;
  const commitBtn = document.getElementById('demo-commit-btn') as HTMLButtonElement;
  const outputEl = document.getElementById('demo-output')!;
  const commitmentValueEl = document.getElementById('demo-commitment-value')!;
  const revealBtn = document.getElementById('demo-reveal-btn')!;
  const revealEl = document.getElementById('demo-reveal')!;
  const revealMEl = document.getElementById('reveal-m')!;
  const revealREl = document.getElementById('reveal-r')!;
  const revealCheckEl = document.getElementById('reveal-check')!;

  let state: { m: bigint; r: bigint; C: bigint } | null = null;

  getGenerators().then(() => {
    statusEl.textContent = 'Ready — classic scheme over a 2048-bit safe-prime subgroup (RFC 3526 Group 14).';
    commitBtn.disabled = false;
  });

  commitBtn.addEventListener('click', async () => {
    commitBtn.disabled = true;
    const m = BigInt(Math.max(0, Math.trunc(Number(mInput.value) || 0)));
    const r = randomExponent();
    const C = await commit(m, r);
    state = { m, r, C };
    commitmentValueEl.textContent = toShortHex(C);
    outputEl.hidden = false;
    revealEl.hidden = true;
    commitBtn.disabled = false;
  });

  revealBtn.addEventListener('click', async () => {
    if (!state) return;
    const ok = await verify(state.m, state.r, state.C);
    revealMEl.textContent = state.m.toString();
    revealREl.textContent = toShortHex(state.r, 20);
    revealCheckEl.textContent = ok
      ? '✓ recomputed g^m · h^r mod p — matches C'
      : '✗ mismatch (this should never happen)';
    revealCheckEl.className = `demo-check ${ok ? 'ok' : 'bad'}`;
    revealEl.hidden = false;
  });
</script>
